---
import '../styles/global.css'
interface Props {
	title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<title>{title}</title>
	</head>
	<body class="bg-slate-900 text-slate-100 font-sans antialiased">
		<slot />
	</body>
</html>