---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

const allPosts: CollectionEntry<"posts">[] = await getCollection("posts");
---

<Layout title="Casos de Estudio | Ricardo Esparza">
  <main class="min-h-screen bg-[#121212] py-20 px-6 text-gray-300">
    <div class="max-w-4xl mx-auto">
      <a href="/" class="text-gray-500 hover:text-white mb-10 inline-block"
        >← Inicio</a
      >
      <h1 class="text-5xl font-bold text-white mb-12">Casos de Estudio</h1>

      <section
        class="mb-10 p-6 bg-[#1a1a1a] border border-zinc-800 rounded-lg shadow-sm"
      >
        <div class="flex items-start gap-4">
          <span class="text-zinc-400 mt-1">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><rect width="18" height="11" x="3" y="11" rx="2" ry="2"
              ></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg
            >
          </span>
          <div>
            <h2
              class="text-zinc-100 font-semibold text-sm uppercase tracking-wider mb-2"
            >
              Aviso de Confidencialidad
            </h2>
            <p class="text-zinc-400 text-sm leading-relaxed italic">
              Por motivos de seguridad y privacidad, los nombres de clientes,
              procesos específicos y datos sensibles han sido anonimizados. Dado
              que estos sistemas residen en intranets privadas, el contenido
              aquí expuesto es una representación técnica de mi lógica de
              ingeniería y procesos de resolución de problemas.
            </p>
          </div>
        </div>
      </section>

      <div class="grid gap-8">
        {
          allPosts.map((post) => (
            <a
              href={`/posts/${post.slug}/`}
              class="group bg-[#1a1a1a] p-8 rounded-2xl border border-gray-800 hover:border-gray-500 transition-all"
            >
              <h2 class="text-2xl font-bold text-white group-hover:text-gray-300 mb-2">
                {post.data.title}
              </h2>
              <p class="text-gray-400 mb-4">{post.data.description}</p>
              <span class="text-sm text-gray-600 font-mono">
                {post.data.date}
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </main>
</Layout>
