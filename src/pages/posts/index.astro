---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

const allPosts: CollectionEntry<'posts'>[] = await getCollection('posts');
---

<Layout title="Casos de Estudio | Ricardo Esparza">
  <main class="min-h-screen bg-[#121212] py-20 px-6 text-gray-300">
    <div class="max-w-4xl mx-auto">
      <a href="/" class="text-gray-500 hover:text-white mb-10 inline-block">← Inicio</a>
      <h1 class="text-5xl font-bold text-white mb-12">Casos de Estudio</h1>
      
      <div class="grid gap-8">
        {allPosts.map(post => (
          <a href={`/posts/${post.slug}`} class="group bg-[#1a1a1a] p-8 rounded-2xl border border-gray-800 hover:border-gray-500 transition-all">
            <h2 class="text-2xl font-bold text-white group-hover:text-gray-300 mb-2">{post.data.title}</h2>
            <p class="text-gray-400 mb-4">{post.data.description}</p>
            <span class="text-sm text-gray-600 font-mono">{post.data.date}</span>
          </a>
        ))}
      </div>
    </div>
  </main>
</Layout>