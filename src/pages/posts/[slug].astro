---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

// 1. Genera las rutas estáticas para cada post
export async function getStaticPaths() {
    const posts = await getCollection("posts");
    return posts.map((post) => ({
        params: { slug: post.slug },
        props: { post },
    }));
}

// 2. Obtiene el post de las props
const { post } = Astro.props;
const { Content } = await post.render();
---

<Layout title={post.data.title}>
    <main class="min-h-screen bg-[#121212] py-20 px-6 text-gray-300">
        <article class="max-w-3xl mx-auto prose prose-invert prose-lg">
            <a
                href="/posts"
                class="text-gray-500 hover:text-white no-underline mb-8 inline-block"
                >← Volver a Casos</a
            >

            <h1 class="text-white text-5xl mb-4 font-bold">
                {post.data.title}
            </h1>
            <time class="text-gray-500 block mb-10 font-mono italic"
                >{post.data.date}</time
            >

            <div
                class="space-y-6 text-gray-400 text-lg leading-relaxed
            [&>h2]:text-white [&>h2]:text-2xl [&>h2]:font-bold [&>h2]:mt-10
            [&>ul]:list-disc [&>ul]:ml-6 [&>ul]:space-y-2
            [&>blockquote]:border-l-4 [&>blockquote]:border-gray-700 [&>blockquote]:pl-4 [&>blockquote]:italic"
            >
                <Content />
            </div>
        </article>
    </main>
</Layout>
